//! Triage agent — entry point.
//!
//! Flow per ticket:
//!   1. parse the line into Ticket fields
//!   2. look the customer up via local memory (k/v)
//!   3. parallel-classify the intent across 3 models (flow_parallel_asks)
//!   4. apply routing policy (VIP / refund threshold / etc.)
//!   5. if auto_reply, draft a response with one more model call
//!   6. record the decision into the audit memory
//!   7. print a one-line summary
//!
//! Capabilities used: Console, LLM, Net, Memory, Tool (no Fs, no Computer).
//! `Tool` is here because `local_memory` returns a Memory value and
//! method calls on it count as the Memory effect; LLM+Net are the
//! standard model-call pair. Audit isn't actually in scope below — we
//! don't call audit_record yet; that's PAPERCUT-008.

use data.{split_pipe, split_lines}
use classify.{classify}
use policy.{decide}

// ---- inlined fixtures (the project caps don't include Fs by design) ----
//
// Keeping the strings as constants instead of `read_file` lets the agent
// run with the minimal cap set. The trade-off is the fixtures are
// duplicated across the .txt files and these consts; in real life one
// would either ship Fs.Read in the cap set or stream from a queue.

const TICKET_LINES = (
    "T-1001|c_alice|Refund for double charge|I was charged $42.50 twice on Tuesday. Please refund one of them.|2026-05-27T10:14:00Z\n" +
    "T-1002|c_bob|App crashes on iOS 17|Every time I open the app it crashes immediately after the splash. I've reinstalled twice.|2026-05-27T10:31:00Z\n" +
    "T-1003|c_carol|VIP: Critical outage in prod|We can't push any deploys; the dashboard returns 503. We have a customer demo in 90 minutes.|2026-05-27T11:02:00Z\n" +
    "T-1004|c_dave|How do I export my data?|I'd like to export everything I have in CSV. Where is that in the settings?|2026-05-27T11:45:00Z\n" +
    "T-1005|c_eve|Refund $128 for unused year|I never used the annual plan. Please refund the whole $128.|2026-05-27T12:10:00Z\n"
)

const CUSTOMER_LINES = (
    "c_alice|Alice Chen|pro|false|3\n" +
    "c_bob|Bob Diaz|free|false|1\n" +
    "c_carol|Carol Wright|enterprise|true|2\n" +
    "c_dave|Dave Ortega|pro|false|0\n" +
    "c_eve|Eve Park|pro|false|1\n"
)

const REFUND_AUTO_THRESHOLD_USD = 50

// ---- per-ticket classifier scripts ----
//
// Each Model is a `mock_model("script", [...])` returning one label per
// ticket. With three models we get realistic consensus arithmetic:
//
//   ticket #1 (refund 42.50): alpha=refund, beta=refund, gamma=refund → refund
//   ticket #2 (bug iOS17):    alpha=bug_report, beta=bug_report, gamma=question → bug_report (2/3)
//   ticket #3 (VIP outage):   alpha=bug_report, beta=question, gamma=bug_report → bug_report (2/3)
//   ticket #4 (data export):  alpha=question, beta=question, gamma=question → question
//   ticket #5 (refund $128):  alpha=refund, beta=refund, gamma=refund → refund
//
// Swap any of these for `anthropic("claude-...")` to drive real models;
// the consensus arithmetic doesn't care.

fn build_classifier_alpha() -> Model {
    mock_model("script", [
        "refund",
        "bug_report",
        "bug_report",
        "question",
        "refund",
    ])
}

fn build_classifier_beta() -> Model {
    mock_model("script", [
        "refund",
        "bug_report",
        "question",
        "question",
        "refund",
    ])
}

fn build_classifier_gamma() -> Model {
    mock_model("script", [
        "refund",
        "question",
        "bug_report",
        "question",
        "refund",
    ])
}

// ---- single drafter model for auto-replies ----

fn build_drafter() -> Model {
    // Only the auto_reply tickets reach the drafter (tickets 0, 1, 3 with
    // the current fixtures). The Script counter is incremented per CALL,
    // so we list responses in call order — not ticket-index order.
    //
    // PAPERCUT-005: the `mock_model("script", [...])` counter is per
    // call rather than indexable by an external key. Whenever a caller
    // skips entries (here: human_review tickets don't call the drafter),
    // the script length and the ticket count diverge. A `MockBehavior`
    // that took a `(ticket_id, response)` map would make this more
    // robust against re-ordering.
    mock_model("script", [
        "Thanks Alice — we've spotted the duplicate charge and queued a refund for one of the $42.50 lines. You'll see it back on your card within 3-5 business days.",
        "Sorry about the iOS crash, Bob. Could you send a screenshot of the splash screen and your iOS build number (Settings > General > About)? In the meantime, try a clean install via TestFlight build 217.",
        "Hi Dave — Settings > Account > Data Export gives you a one-click CSV bundle. The job emails you when it's ready (usually under 5 minutes).",
    ])
}

fn refund_amount_for(ticket_index: Int) -> Int {
    if ticket_index == 0 { return 42 }   // ticket #1 — $42.50 → 42 (Int-only world)
    if ticket_index == 4 { return 128 }  // ticket #5
    0
}

fn customer_vip(line: String) -> Bool {
    let parts = split_pipe(line)
    list_get(parts, 3) == "true"
}

fn lookup_customer_line(id: String, all_lines: List<String>) -> String {
    var i = 0
    while i < list_len(all_lines) {
        let line = list_get(all_lines, i)
        let parts = split_pipe(line)
        if list_get(parts, 0) == id { return line }
        i = i + 1
    }
    ""
}

fn customer_name(line: String) -> String {
    let parts = split_pipe(line)
    list_get(parts, 1)
}

fn main() uses { Console, LLM, Net, Memory, Tool } {
    let m1 = build_classifier_alpha()
    let m2 = build_classifier_beta()
    let m3 = build_classifier_gamma()
    let drafter = build_drafter()
    let audit = local_memory()

    let tickets = split_lines(TICKET_LINES)
    let customers = split_lines(CUSTOMER_LINES)

    print("---- triage run ----")
    print("tickets: " + str(list_len(tickets)))
    print("customers: " + str(list_len(customers)))
    print("refund auto-approval threshold: $" + str(REFUND_AUTO_THRESHOLD_USD))
    print("")

    var i = 0
    var decisions_auto = 0
    var decisions_human = 0
    var decisions_escalate = 0
    while i < list_len(tickets) {
        let line = list_get(tickets, i)
        let parts = split_pipe(line)
        let ticket_id = list_get(parts, 0)
        let customer_id = list_get(parts, 1)
        let subject = list_get(parts, 2)
        let body = list_get(parts, 3)

        let cust_line = lookup_customer_line(customer_id, customers)
        let is_vip = customer_vip(cust_line)
        let name = customer_name(cust_line)

        let intent = classify(m1, m2, m3, subject, body)
        let refund_usd = refund_amount_for(i)

        let outcome = decide(intent, refund_usd, is_vip, REFUND_AUTO_THRESHOLD_USD)
        let action = list_get(outcome, 0)
        let reason = list_get(outcome, 1)

        var draft = ""
        if action == "auto_reply" {
            draft = ask drafter { user: subject }
        }

        // Record into the audit log; later we recall by ticket_id.
        audit.store(
            "ticket=" + ticket_id +
            " customer=" + name +
            " intent=" + intent +
            " action=" + action +
            " reason=" + reason
        )

        print("[" + ticket_id + "] " + name + " (vip=" + str(is_vip) + ")")
        print("    intent: " + intent + ", refund_usd: " + str(refund_usd))
        print("    action: " + action + " — " + reason)
        if action == "auto_reply" {
            print("    draft : " + str_substring(draft, 0, min_int(60, str_len(draft))) + "...")
        }
        print("")

        if action == "auto_reply" { decisions_auto = decisions_auto + 1 }
        if action == "human_review" { decisions_human = decisions_human + 1 }
        if action == "escalate" { decisions_escalate = decisions_escalate + 1 }
        i = i + 1
    }

    print("---- summary ----")
    print("auto_reply  : " + str(decisions_auto))
    print("human_review: " + str(decisions_human))
    print("escalate    : " + str(decisions_escalate))

    // Recall the audit log for VIP records, proving Memory.recall round-
    // trips through substring search.
    let vip_records = audit.recall("Carol")
    print("audit recall(\"Carol\") returned " + str(list_len(vip_records)) + " record(s)")
}

fn min_int(a: Int, b: Int) -> Int {
    if a < b { a } else { b }
}
